# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GOOGLE_MAPS_PLATFORM_KEY: Required for Google Maps Platform APIs (Maps, Places, Solar, Aerial View, Air Quality).
# Users configure this via the Secrets panel in the AI Studio UI.
GOOGLE_MAPS_PLATFORM_KEY="YOUR_GOOGLE_MAPS_PLATFORM_KEY"

# FAL_KEY: Required for FLUX inpainting (mask-based area editing) and SAM 2 segmentation.
# Get your key at https://fal.ai/dashboard/keys
# Without this key, full garden transformations still work (via Gemini),
# but area-specific mask editing will not be available.
FAL_KEY="your_fal_key_here"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
